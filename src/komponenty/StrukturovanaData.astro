---
// ============================================================
// StrukturovanaData.astro
// JSON-LD strukturovaná data podle schema.org.
//
// ★ Identita, adresa, kontakty a sociální sítě se čtou z jednoho
//   zdroje pravdy: src/data/kontakt.ts. ★
// Tady dolaď jen popis služeb a expertní oblasti (knowsAbout).
//
// Vkládá se do <head> hlavní stránky.
// ============================================================

import { kontakt } from '../data/kontakt';

const web = kontakt.domena.replace(/\/$/, ''); // bez lomítka na konci
const autor = [kontakt.titul, kontakt.jmeno].filter(Boolean).join(' ');

// Sociální sítě → pole neprázdných odkazů (sameAs)
const sameAs = Object.values(kontakt.socialniSite).filter(Boolean);

const data = {
	"@context": "https://schema.org",
	"@graph": [
		// 1. Značka jako podnik
		{
			"@type": ["ProfessionalService", "LocalBusiness"],
			"@id": `${web}/#business`,
			"name": kontakt.znacka,
			"alternateName": `${autor} — ${kontakt.znacka}`,
			"description": kontakt.popis,
			"url": web,
			"telephone": kontakt.telefon,
			"email": kontakt.email,
			"image": `${web}/og-image.png`,
			"logo": `${web}/favicon.svg`,
			"address": {
				"@type": "PostalAddress",
				"postalCode": kontakt.adresa.PSC,
				"addressLocality": kontakt.adresa.mesto,
				"addressRegion": kontakt.adresa.kraj,
				"addressCountry": kontakt.adresa.zeme
			},
			"areaServed": [
				{ "@type": "City", "name": kontakt.adresa.mesto },
				{ "@type": "Country", "name": "Česká republika" }
			],
			"founder": { "@id": `${web}/#autor` },
			"employee": { "@id": `${web}/#autor` },
			"makesOffer": [
				{ "@id": `${web}/#sluzba-1` }
			],
			"sameAs": sameAs
		},

		// 2. Autor jako konkrétní osoba
		{
			"@type": "Person",
			"@id": `${web}/#autor`,
			"name": autor,
			"jobTitle": kontakt.pozice,
			"description": "Krátký popis autora a jeho přístupu.",
			"url": `${web}/kdo-jsem`,
			"image": `${web}/og-image.png`,
			"worksFor": { "@id": `${web}/#business` },
			"knowsAbout": [
				"Expertní oblast 1",
				"Expertní oblast 2",
				"Expertní oblast 3"
			],
			"knowsLanguage": ["cs"],
			"nationality": { "@type": "Country", "name": "Česká republika" }
		},

		// 3. Služba (zkopíruj a pozměň pro další služby)
		{
			"@type": "Service",
			"@id": `${web}/#sluzba-1`,
			"name": "Název služby",
			"serviceType": "Typ služby",
			"description": "Popis služby s klíčovými slovy.",
			"url": `${web}/sluzba-1`,
			"provider": { "@id": `${web}/#business` },
			"areaServed": { "@type": "Country", "name": "Česká republika" }
		}
	]
};
---

<script type="application/ld+json" set:html={JSON.stringify(data)} />
